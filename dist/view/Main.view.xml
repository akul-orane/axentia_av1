<mvc:View
  controllerName="com.demo.fioriapp.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Page id="mainPage" title="Z_CDS_AKULPRACT - OData App" showHeader="true">
    <subHeader>
      <Toolbar>
        <SearchField
          id="searchField"
          placeholder="Search..."
          width="30%"
          liveChange="onSearch" />
        <ToolbarSpacer />
        <Button
          text="Refresh"
          icon="sap-icon://refresh"
          press="onRefresh" />
      </Toolbar>
    </subHeader>

    <content>
      <Table
        id="mainTable"
        items="{/Z_CDS_AKULPRACT}"
        growing="true"
        growingThreshold="30"
        growingScrollToLoad="true"
        noDataText="No data found. Check console or error message.">
        <headerToolbar>
          <Toolbar>
            <Title text="CDS View Data (Z_CDS_AKULPRACT)" level="H2" />
            <ToolbarSpacer />
            <Label text="Showing {=${/Z_CDS_AKULPRACT}.length || 0} records" design="Bold" />
          </Toolbar>
        </headerToolbar>
        <columns>
          <Column width="10rem">
            <Text text="Billing Document" />
          </Column>
          <Column width="6rem">
            <Text text="Item" />
          </Column>
          <Column width="auto" minScreenWidth="Tablet" demandPopin="true">
            <Text text="Customer" />
          </Column>
          <Column width="auto">
            <Text text="Material" />
          </Column>
          <Column width="12rem">
            <Text text="Material Description" />
          </Column>
          <Column width="8rem" hAlign="End">
            <Text text="Quantity" />
          </Column>
          <Column width="8rem" hAlign="End">
            <Text text="Net Revenue" />
          </Column>
        </columns>
        <items>
          <ColumnListItem type="Active" press="onItemPress">
            <cells>
              <Text text="{BillingDocument}" />
              <Text text="{BillingItem}" />
              <Text text="{Customer} - {CustomerName}" />
              <Text text="{Material}" />
              <Text text="{MaterialDescription}" />
              <Text text="{BillingQuantity} {BillingUoM}" />
              <Text text="{NetRevenue} {Currency}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </content>

    <footer>
      <Toolbar>
        <ToolbarSpacer />
        <Button
          text="Refresh Data"
          type="Emphasized"
          icon="sap-icon://refresh"
          press="onRefresh" />
      </Toolbar>
    </footer>
  </Page>

</mvc:View>
