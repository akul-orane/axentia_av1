<mvc:View
  controllerName="com.demo.fioriapp.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

      <Page id="mainPage" title="Z_CDS_AKULPRACT - OData App" showHeader="true">
    <subHeader>
      <Toolbar>
        <SearchField
          id="searchField"
          placeholder="Search by ID or Name..."
          width="30%"
          liveChange="onSearch" />
        <ToolbarSpacer />
        <Button
          text="Refresh"
          icon="sap-icon://refresh"
          press="onRefresh" />
      </Toolbar>
    </subHeader>

    <content>
      <Table
        id="mainTable"
        items="{/Z_CDS_AKULPRACT}"
        growing="true"
        growingThreshold="30"
        growingScrollToLoad="true"
        noDataText="No data found. Check console for errors.">
        <headerToolbar>
          <Toolbar>
            <Title text="Z_CDS_AKULPRACT Data" level="H2" />
            <ToolbarSpacer />
            <Label text="Showing {=${/Z_CDS_AKULPRACT}.length || 0} records" design="Bold" />
          </Toolbar>
        </headerToolbar>
        <columns>
          <Column width="10rem">
            <Text text="ID" />
          </Column>
          <Column width="auto" minScreenWidth="Tablet" demandPopin="true">
            <Text text="Name / Description" />
          </Column>
          <Column width="12rem">
            <Text text="Status" />
          </Column>
          <Column width="10rem">
            <Text text="Date" />
          </Column>
        </columns>
        <items>
          <ColumnListItem type="Active" press="onItemPress">
            <cells>
              <ObjectIdentifier title="{ID}" />
              <Text text="{Name}" />
              <Text text="{Status}" />
              <Text text="{Date}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </content>

    <footer>
      <Toolbar>
        <ToolbarSpacer />
        <Button
          text="Create New"
          type="Emphasized"
          icon="sap-icon://add"
          press="onCreatePress" />
      </Toolbar>
    </footer>
  </Page>

</mvc:View>